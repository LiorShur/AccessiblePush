{
  "name": "accessible-nature",
  "version": "1.0.0-beta",
  "description": "Making paths clear for everyone. Track trails, report barriers, and discover accessible routes.",
  "main": "index.html",
  "scripts": {
    "start": "npx serve .",
    "cap:sync": "npx cap sync",
    "cap:copy": "npx cap copy",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:run:android": "npx cap run android",
    "cap:run:ios": "npx cap run ios",
    "cap:build:android": "npx cap sync android && cd android && ./gradlew assembleDebug",
    "cap:build:android:release": "npx cap sync android && cd android && ./gradlew assembleRelease",
    "android:studio": "npx cap open android",
    "ios:xcode": "npx cap open ios"
  },
  "keywords": [
    "accessibility",
    "trails",
    "navigation",
    "pwa",
    "capacitor",
    "hybrid"
  ],
  "author": "Access Nature Team",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/device": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/network": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor-community/keep-awake": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "serve": "^14.2.0",
    "typescript": "^5.4.0"
  }
}
